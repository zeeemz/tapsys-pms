# Copy to .env and fill in.
# Local dev (SQLite): DATABASE_URL="file:./dev.db"
# Production (Render Postgres): DATABASE_URL="postgresql://user:pass@host:5432/dbname"
# The DB provider is auto-detected from the URL scheme (file: -> sqlite, postgres* -> postgresql).
DATABASE_URL="file:./dev.db"

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-string"

# Shared demo password seeded for all demo accounts.
DEMO_PASSWORD="tapsys"

# Port the server listens on (Render sets PORT automatically).
PORT=7433
