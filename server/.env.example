# Copy to .env and fill in.
# Local dev (SQLite): DATABASE_URL="file:./dev.db"
# Production (Render Postgres): DATABASE_URL="postgresql://user:pass@host:5432/dbname"
# The DB provider is auto-detected from the URL scheme (file: -> sqlite, postgres* -> postgresql).
DATABASE_URL="file:./dev.db"

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-string"

# Shared demo password seeded for all demo accounts.
DEMO_PASSWORD="tapsys"

# Port the server listens on (Render sets PORT automatically).
PORT=7433

# Microsoft Entra ID (Azure AD) SSO — leave blank to disable. When all three are set,
# a "Sign in with Microsoft" button appears for @<AAD_ALLOWED_DOMAIN> staff.
AAD_TENANT_ID=
AAD_CLIENT_ID=
AAD_CLIENT_SECRET=
AAD_ALLOWED_DOMAIN=paysyslabs.com
# Optional: explicit redirect URI registered on the app (else derived from the request host).
# e.g. https://tapsys-pms-3huqr.azurewebsites.net/api/auth/aad/callback
AAD_REDIRECT_URI=
